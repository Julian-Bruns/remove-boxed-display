{
  "manifest_version": 3,
  "name": "ChatGPT Math Normalizer",
  "description": "Removes boxed KaTeX styling and converts ChatGPT display math to inline flow.",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-math-normalizer@julian-bruns.local"
    }
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "ChatGPT Math Normalizer",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "css": [
        "vendor/katex/katex.min.css",
        "content.css"
      ],
      "js": [
        "extension-api.js",
        "vendor/katex/katex.min.js",
        "tex-normalizer.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/katex/fonts/*"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ]
}
